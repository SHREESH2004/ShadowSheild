{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "target": "ES2020",
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ]
  },
"include": [
    "src/index.ts",
    "src/packageIndex.ts",
    "src/app.ts",
    "src/middleware/**/*",
    "src/engines/**/*",
    "src/config/schema.ts",
    "src/cron/**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/test/**/*",
    "src/routes/**/*",
    "src/redis_client/**/*"
  ]
}