{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "target": "ES2020",
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "src/packageIndex.ts",
    "src/middleware/**/*",
    "src/engines/**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/index.ts",
    "src/app.ts",
    "src/config/**/*",
    "src/cron/**/*",
    "src/redis_client/**/*",
    "src/routes/**/*",
    "src/test/**/*"
  ]
}